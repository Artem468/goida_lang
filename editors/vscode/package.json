{
    "name": "goida-vscode",
    "displayName": "Goida Language Support",
    "version": "0.0.1",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/Artem468/goida_lang.git",
        "directory": "editors/vscode"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "activationEvents": [
        "onLanguage:goida"
    ],
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "build:lsp": "cargo build -p lsp",
        "copy:lsp": "node ./scripts/copy-lsp.js",
        "typecheck": "tsc -p ./ --noEmit",
        "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --outfile=out/extension.js",
        "compile": "npm run build:lsp && npm run typecheck && npm run bundle && npm run copy:lsp",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "contributes": {
        "languages": [
            {
                "id": "goida",
                "extensions": [
                    ".goida"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "goida",
                "scopeName": "source.goida",
                "path": "./syntaxes/goida.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "Goida",
            "properties": {
                "goida.languageServer.path": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to goida LSP binary. If empty, extension tries bundled and workspace binaries."
                }
            }
        }
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.75.0",
        "esbuild": "^0.28.0",
        "typescript": "^6.0.2"
    }
}
