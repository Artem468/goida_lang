{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "goida",
  "scopeName": "source.goida",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#import"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#classes"
    },
    {
      "include": "#namespaces"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#variable-declaration"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.goida",
      "match": "//.*$"
    },
    "namespaces": {
      "patterns": [
        {
          "name": "entity.name.namespace.goida",
          "match": "\\b[邪-褟袗-携_][邪-褟袗-携0-9_]*(?=\\.)"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.goida",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.goida",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.goida",
      "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.goida",
          "match": "\\b(械褋谢懈|懈薪邪褔械|锌芯泻邪|写谢褟|胁械褉薪褍褌褜|锌械褔邪褌褜|胁胁芯写|锌械褉械屑械薪薪邪褟|斜懈斜谢懈芯褌械泻邪|锌芯写泻谢褞褔懈褌褜|褌懈锌|胁|薪芯胁褘泄|褎褍薪泻褑懈褟)\\b"
        },
        {
          "name": "storage.type.goida",
          "match": "\\b(褌械泻褋褌|褔懈褋谢芯|谢芯谐懈褔械褋泻懈泄|写褉芯斜褜|褋锌懈褋芯泻|屑邪褋褋懈胁|褋谢芯胁邪褉褜|孝械泻褋褌|小锌懈褋芯泻|袦邪褋褋懈胁|小谢芯胁邪褉褜|肖邪泄谢|孝械褉屑懈薪邪谢|袛邪褌邪袙褉械屑褟|小懈褋褌械屑邪)\\b"
        },
        {
          "name": "constant.language.goida",
          "match": "\\b(懈褋褌懈薪邪|谢芯卸褜|褝褌芯|锌褍褋褌芯褌邪)\\b"
        },
        {
          "name": "entity.name.function.goida",
          "match": "\\b[邪-褟袗-携_][邪-褟袗-携0-9_]*(?=\\()"
        },
        {
          "name": "variable.other.object.goida",
          "match": "([邪-褟袗-携_][邪-褟袗-携0-9_]*)(?=\\.)"
        },
        {
          "name": "variable.other.property.goida",
          "match": "(?<=\\.)[邪-褟袗-携_][邪-褟袗-携0-9_]*\\b"
        },
        {
          "name": "punctuation.goida",
          "match": "[{}()\\[\\];,.]"
        }
      ]
    },
    "import": {
      "begin": "(\\b锌芯写泻谢褞褔懈褌褜\\b)\\s*(\")",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.import.goida"
        },
        "2": {
          "name": "string.quoted.double.goida"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "string.quoted.double.goida"
        }
      },
      "patterns": [
        {
          "name": "entity.name.namespace.goida",
          "match": "[邪-褟袗-携_][邪-褟袗-携0-9_]*"
        },
        {
          "name": "punctuation.separator.path.goida",
          "match": "/"
        }
      ]
    },
    "classes": {
      "name": "entity.name.class.goida",
      "match": "\\b(泻谢邪褋褋|锌褍斜谢懈褔薪褘泄|锌褉懈胁邪褌薪褘泄|泻芯薪褋褌褉褍泻褌芯褉)\\b"
    },
    "operators": {
      "name": "keyword.operator.goida",
      "match": "[=+\\-*/%]"
    },
    "variable-declaration": {
      "name": "variable.other.definition.goida",
      "match": "\\b[邪-褟袗-携_][邪-褟袗-携0-9_]*(?=\\s*=)"
    },
    "variables": {
      "name": "variable.name.goida",
      "match": "\\b[邪-褟袗-携_][邪-褟袗-携0-9_]*\\b"
    }
  }
}