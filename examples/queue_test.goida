класс Очередь {
    приватный данные: список

    публичный конструктор новый(это) {
        это.данные = список()
    }

    публичный функция enqueue(это, v) {
        это.данные.добавить(v)
    }

    публичный функция dequeue(это) {
        вернуть это.данные.удалить(0)
    }

    публичный функция длина(это) {
        вернуть это.данные.длина()
    }
}

q = новый Очередь()
q.enqueue(1)
q.enqueue(2)
печать(q.dequeue())
печать(q.dequeue())
печать(q.длина())
