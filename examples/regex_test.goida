// Пример класса РегулярноеВыражение и основных методов.
рег = новый РегулярноеВыражение("([A-Za-z]+)-([0-9]+)")

печать(рег.шаблон())
печать(рег.совпадает("ticket-42"))
печать(рег.найти("id=ticket-42; id=task-7"))
печать(рег.найти_все("ticket-42 task-7 none"))
печать(рег.группы("ticket-42"))
печать(рег.группы_все("ticket-42 task-7"))
печать(рег.заменить("ticket-42 task-7", "item"))
печать(рег.заменить_все("ticket-42 task-7", "item"))
печать(рег.разделить("ticket-42, task-7, none"))

// Короткая форма через встроенную функцию.
слова = регулярное_выражение("[а-яА-Я]+")
печать(слова.найти_все("три слова здесь"))

