функция умн_2(ч) { вернуть ч * 2 }
функция больше_4(ч) { вернуть ч > 4 }

сп = список(1, 2, 3, 4)
рез = список()
для (i = 0, i < сп.длина(), i += 1) {
    рез.добавить(умн_2(сп[i]))
}

ф = список()
для (i = 0, i < рез.длина(), i += 1) {
    если (рез[i] > 4) {
        ф.добавить(рез[i])
    }
}

для (i = 0, i < ф.длина(), i += 1) {
    печать(ф[i])
}
