класс Стек {
    приватный данные: список

    публичный конструктор новый(это) {
        это.данные = список()
    }

    публичный функция положить(это, элемент) {
        это.данные.добавить(элемент)
    }

    публичный функция удалить(это) {
        вернуть это.данные.удалить(это.данные.длина() - 1)
    }

    публичный функция длина(это) {
        вернуть это.данные.длина()
    }
}

с = новый Стек()
с.положить(10)
с.положить(20)
печать(с.удалить())
печать(с.удалить())
печать(с.длина())
