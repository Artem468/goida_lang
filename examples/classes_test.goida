класс A {
    публичный поле: число;

    публичный конструктор новый(это, v) {
        это.поле = v;
    }

    публичный функция взять(это) {
        вернуть это.поле;
    }
}

класс B(A) {
    публичный функция удвоить(это) {
        вернуть это.поле * 2;
    }
}

o = новый B(7);
печать(o.взять());
печать(o.удвоить());
