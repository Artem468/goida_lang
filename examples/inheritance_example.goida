класс Животное {
    публичный имя: строка = "без имени"

    публичный конструктор Животное(это, имя: строка) {
        это.имя = имя
    }

    публичный функция описание(это) -> строка {
        вернуть "Имя: " + это.имя
    }
}

класс Собака(Животное) {
    публичный функция голос(это) -> строка {
        вернуть это.имя + " говорит гав"
    }
}

питомец = новый Собака("Шарик")
печать(питомец.описание())
печать(питомец.голос())
