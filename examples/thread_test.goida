значение = новый Мьютекс(1)

функция работа(общее, новое) {
    общее.блокировать()
    общее.записать(новое)
    общее.разблокировать()
}

t = Поток.создать(работа, значение, 2)
t.ждать()
печать(значение.прочитать())

u = новый Поток(работа, значение, 3)
u.ждать()
печать(значение.прочитать())

хранилище = новый БлокировкаЧтенияЗаписи("до")
поток {
    хранилище.писать_блокировать()
    хранилище.записать("после")
    хранилище.писать_разблокировать()
}
