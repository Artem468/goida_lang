данные = словарь(
    "имя", "Гойда",
    "версия", 1,
    "флаги", список("json", "http"),
    "включен", истина,
    "вложенный", словарь("ключ", "значение")
);

json = в_json(данные);
печать("JSON:", json);

обратно = из_json(json);
печать("Тип после разбора:", тип(обратно));
печать("Имя:", обратно["имя"]);
печать("Первый флаг:", обратно["флаги"][0]);
печать("Вложенный ключ:", обратно["вложенный"]["ключ"]);
