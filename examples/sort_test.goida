функция сортировка_пузырьком(сп) {
    дл = сп.длина();
    для (i = 0; i < дл; i += 1) {
        для (j = 1; j < дл - i; j += 1) {
            если (сп[j - 1] > сп[j]) {
                врем = сп[j - 1];
                сп.задать(j - 1, сп[j]);
                сп.задать(j, врем);
            }
        }
    }
    вернуть сп;
}

сп = список(3, 1, 2);
сп = сортировка_пузырьком(сп);
для (i = 0; i < сп.длина(); i += 1) {
    печать(сп[i]);
}
