function arithmetic_workload(rounds, limit) {
    checksum = 0
    for (round = 0, round < rounds, round += 1) {
        total = 0
        for (i = 0, i < limit, i += 1) {
            total += i * 3 + 1
        }
        checksum += total
    }
    return checksum
}

result = arithmetic_workload(10, 100000)
